# ---------------------------------------------------------------------------
# mymap — משתני סביבה (תבנית)
# העתק קובץ זה ל-.env והחלף כל ערך change_me_* בסיסמה חזקה לפני ההרצה.
#     קובץ .env עצמו לא נכנס ל-git (ראה .gitignore).
# ---------------------------------------------------------------------------

# --- PostGIS ---
PG_DB=gis
PG_USER=gis
PG_PASSWORD=change_me_postgis

# --- GeoServer ---
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=change_me_geoserver

# --- Keycloak (admin) ---
KC_PASSWORD=change_me_keycloak

# --- MinIO (הסיסמה חייבת להיות באורך 8 תווים לפחות) ---
MINIO_USER=mymap
MINIO_PASSWORD=change_me_minio

# --- OpenSearch heap (התאם לזיכרון הפנוי; לדוגמה 2g או 4g) ---
OPENSEARCH_HEAP=2g
